generator client { provider = "prisma-client-js" }

datasource db { provider = "postgresql" url = env("DATABASE_URL") }

model Practice { id String @id @default(uuid()) name String brandColor String @default("#579a76") users User[] entities BusinessEntity[] createdAt DateTime @default(now()) }
model User { id String @id @default(uuid()) practiceId String practice Practice @relation(fields:[practiceId], references:[id]) email String @unique fullName String role String mfaEnabled Boolean @default(false) createdAt DateTime @default(now()) }
model BusinessEntity { id String @id @default(uuid()) practiceId String practice Practice @relation(fields:[practiceId], references:[id]) legalName String companyNumber String? companyStatus String? companyHouseSyncedAt DateTime? utrEncrypted String? vatNumberEncrypted String? payeReferenceEncrypted String? accountsOfficeEncrypted String? entityType String vatScheme String @default("standard") financialYearStart DateTime chartAccounts ChartAccount[] journalEntries JournalEntry[] employees Employee[] vatPeriods VatPeriod[] auditEvents AuditEvent[] createdAt DateTime @default(now()) }
model ChartAccount { id String @id @default(uuid()) entityId String entity BusinessEntity @relation(fields:[entityId], references:[id]) code String name String accountType String systemAccount Boolean @default(false) active Boolean @default(true) lines JournalLine[] @@unique([entityId, code]) }
model JournalEntry { id String @id @default(uuid()) entityId String entity BusinessEntity @relation(fields:[entityId], references:[id]) sourceType String sourceId String? description String accountingDate DateTime postedAt DateTime? lockedAt DateTime? lines JournalLine[] createdAt DateTime @default(now()) }
model JournalLine { id String @id @default(uuid()) journalEntryId String journalEntry JournalEntry @relation(fields:[journalEntryId], references:[id]) accountId String account ChartAccount @relation(fields:[accountId], references:[id]) debit Decimal @default(0) credit Decimal @default(0) taxCode String? }
model Employee { id String @id @default(uuid()) entityId String entity BusinessEntity @relation(fields:[entityId], references:[id]) payrollId String firstNameEncrypted String lastNameEncrypted String niNumberEncrypted String? taxCode String niCategory String pensionStatus String status String @default("active") payslips Payslip[] @@unique([entityId, payrollId]) }
model PayrollRun { id String @id @default(uuid()) entityId String taxYear String taxPeriod Int paymentDate DateTime status String @default("draft") grossPayTotal Decimal @default(0) payeTotal Decimal @default(0) employeeNiTotal Decimal @default(0) employerNiTotal Decimal @default(0) pensionTotal Decimal @default(0) netPayTotal Decimal @default(0) payslips Payslip[] rtiSubmissions RtiSubmission[] }
model Payslip { id String @id @default(uuid()) payrollRunId String payrollRun PayrollRun @relation(fields:[payrollRunId], references:[id]) employeeId String employee Employee @relation(fields:[employeeId], references:[id]) grossPay Decimal payeTax Decimal employeeNi Decimal employerNi Decimal pension Decimal netPay Decimal ytdValues Json pdfObjectKey String? }
model VatPeriod { id String @id @default(uuid()) entityId String entity BusinessEntity @relation(fields:[entityId], references:[id]) scheme String periodStart DateTime periodEnd DateTime status String @default("open") boxValues Json? submittedAt DateTime? }
model RtiSubmission { id String @id @default(uuid()) payrollRunId String payrollRun PayrollRun @relation(fields:[payrollRunId], references:[id]) submissionType String status String @default("draft") payload Json response Json? submittedAt DateTime? }
model AuditEvent { id String @id @default(uuid()) entityId String? entity BusinessEntity? @relation(fields:[entityId], references:[id]) actorId String? action String metadata Json createdAt DateTime @default(now()) }
